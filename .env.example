# =============================================================================
# Ordo HQ — Environment Variables
# =============================================================================

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
#
# IMPORTANT: When deploying to a new domain, you MUST add the callback URL
# in Google Cloud Console under "Authorized redirect URIs":
#   https://YOUR_DOMAIN/api/auth/callback/google
# OAuth will fail silently on any unregistered domain.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth ---
# Generate with: openssl rand -base64 32
#
# WARNING: Changing AUTH_SECRET invalidates ALL user sessions (mass logout).
# When migrating to a new host, carry over the SAME secret from the previous
# environment to preserve existing sessions.
AUTH_SECRET=

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/ordo_hq

# --- Admin ---
ADMIN_EMAILS=hunter@ordoschools.com,sheila@ordoschools.com

# --- Storage (image uploads) ---
# The app auto-selects a storage backend based on which vars are set:
#   1. If BLOB_READ_WRITE_TOKEN is set → Vercel Blob
#   2. If S3_BUCKET is set → S3-compatible (AWS, DigitalOcean Spaces, MinIO)
#   3. Otherwise → local filesystem (public/uploads/)

# Vercel Blob (set automatically on Vercel)
# BLOB_READ_WRITE_TOKEN=

# S3-compatible storage (DigitalOcean Spaces)
# S3_BUCKET=hq-space
# S3_REGION=sfo3
# S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Deployment (Docker / self-hosted only) ---
# PORT=3000
# SEED_ON_DEPLOY=false
