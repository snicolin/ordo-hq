generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DisplayType {
  BUTTON
  LINK
  TILE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  isAdmin   Boolean  @default(false)
  groupId   String?
  lastLogin DateTime @default(now())
  createdAt DateTime @default(now())

  group             Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  bannerDismissals  BannerDismissal[]
}

model Page {
  id     String  @id @default(cuid())
  label  String
  slug   String  @unique
  order  Int     @default(0)
  isHome Boolean @default(false)

  sections   PageSection[]
  itemPages  ItemPage[]
  groupsHome Group[]       @relation("GroupDefaultPage")
}

model Section {
  id          String      @id @default(cuid())
  title       String
  hideTitle   Boolean     @default(false)
  displayType DisplayType

  pages PageSection[]
  items Item[]
}

model PageSection {
  pageId        String
  sectionId     String
  order         Int      @default(0)

  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([pageId, sectionId])
}

model Item {
  id          String  @id @default(cuid())
  sectionId   String
  name        String
  href        String
  description String?
  image       String?
  disabled    Boolean @default(false)
  order       Int     @default(0)

  section Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  pages   ItemPage[]
}

model ItemPage {
  itemId String
  pageId String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([itemId, pageId])
}

model Group {
  id            String   @id @default(cuid())
  name          String
  defaultPageId String?
  createdAt     DateTime @default(now())

  defaultPage Page?    @relation("GroupDefaultPage", fields: [defaultPageId], references: [id], onDelete: SetNull)
  members     User[]
  banners     Banner[]
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  body        String?
  color       String   @default("YELLOW")
  icon        String?
  link        String?
  dismissible Boolean  @default(true)
  expiresAt   DateTime
  targetType  String   @default("ALL")
  groupId     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  group      Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  dismissals BannerDismissal[]
}

model BannerDismissal {
  userId      String
  bannerId    String
  dismissedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@id([userId, bannerId])
}

model Setting {
  key   String @id
  value String
}
