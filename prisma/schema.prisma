generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  image            String?
  isAdmin          Boolean           @default(false)
  lastLogin        DateTime          @default(now())
  createdAt        DateTime          @default(now())
  groupId          String?
  bannerDismissals BannerDismissal[]
  group            Group?            @relation(fields: [groupId], references: [id])
}

model Page {
  id         String        @id @default(cuid())
  label      String
  slug       String        @unique
  order      Int           @default(0)
  isHome     Boolean       @default(false)
  groupsHome Group[]       @relation("GroupDefaultPage")
  itemPages  ItemPage[]
  sections   PageSection[]
}

model Section {
  id          String        @id @default(cuid())
  title       String
  displayType DisplayType
  hideTitle   Boolean       @default(false)
  content     String?
  targetDate  DateTime?
  items       Item[]
  pages       PageSection[]
}

model PageSection {
  pageId    String
  sectionId String
  order     Int     @default(0)
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([pageId, sectionId])
}

model Item {
  id          String     @id @default(cuid())
  sectionId   String
  name        String
  href        String     @default("")
  description String?
  image       String?
  disabled    Boolean    @default(false)
  order       Int        @default(0)
  apiField    String?
  apiUrl      String?
  value       String?
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  pages       ItemPage[]
}

model ItemPage {
  itemId String
  pageId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([itemId, pageId])
}

model Group {
  id            String   @id @default(cuid())
  name          String
  defaultPageId String?
  createdAt     DateTime @default(now())
  banners       Banner[]
  defaultPage   Page?    @relation("GroupDefaultPage", fields: [defaultPageId], references: [id])
  members       User[]
}

model Banner {
  id          String            @id @default(cuid())
  title       String
  body        String?
  dismissible Boolean           @default(true)
  expiresAt   DateTime
  targetType  String            @default("ALL")
  groupId     String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  color       String            @default("YELLOW")
  icon        String?
  link        String?
  group       Group?            @relation(fields: [groupId], references: [id])
  dismissals  BannerDismissal[]
}

model BannerDismissal {
  userId      String
  bannerId    String
  dismissedAt DateTime @default(now())
  banner      Banner   @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, bannerId])
}

model Setting {
  key   String @id
  value String
}

enum DisplayType {
  BUTTON
  LINK
  TILE
  METRIC
  TEXT
  COUNTDOWN
}
